                                <Border Background="{StaticResource BorderBrushBase}" CornerRadius="5"/>
                                <Border x:Name="UsageBar" Background="{StaticResource AccentBrush}" CornerRadius="5"
                                        HorizontalAlignment="Left" Width="0"/>
