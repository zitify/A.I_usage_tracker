<Window x:Class="AIUsageTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:AIUsageTracker.Views"
        Title="A.I. Usage Tracker"
        Width="940" Height="820"
        MinWidth="820" MinHeight="720"
        Background="{StaticResource BgBaseBrush}"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico"
        SourceInitialized="Window_SourceInitialized"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>


    <Border x:Name="RootBorder" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ CUSTOM TITLE BAR ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BgTitleBarBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="0,0,0,1" Height="36">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                    <!-- Normal theme icon -->
                    <Image x:Name="NormalTitleIcon"
                           Source="/Assets/Square44x44Logo.png" Width="16" Height="16"
                           Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <!-- Dog theme corgi icon (hidden until dog mode) -->
                    <Image x:Name="DogTitleIcon"
                           Source="{DynamicResource CorgiPawImage}" Width="26" Height="26"
                           Margin="0,0,8,0" Visibility="Collapsed"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="A.I. Usage Tracker" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TitleBarTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DogTitlePaw" Text=" 🐾" FontSize="11"
                               Foreground="{StaticResource TitleBarTextBrush}" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- 헤더 5개 버튼: Path/Geometry 기반 렌더링 (BrandIcons.xaml 의 ChromeIcon* 리소스).
                     글꼴 폴백(컬러 이모지) 영향이 원천 차단되어 Foreground 토큰을 정확히 따름. -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 강아지 모드 설정 (활성 시에만 표시) -->
                    <Button x:Name="DogSettingsBtn"
                            Content="{StaticResource ChromeIconPaw}"
                            ToolTip="화면에 등장시킬 강아지 종 선택"
                            Style="{StaticResource ChromeBtn}"
                            Visibility="Collapsed"
                            Click="DogSettingsBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <!-- 견종 선택 팝업 -->
                    <Popup x:Name="DogSettingsPopup" StaysOpen="False"
                           Placement="Bottom" PlacementTarget="{Binding ElementName=DogSettingsBtn}"
                           AllowsTransparency="True">
                        <Border Background="{DynamicResource BgCardBrush}"
                                BorderBrush="{DynamicResource BorderStrongBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,10" MinWidth="200"
                                Effect="{x:Null}">
                            <StackPanel>
                                <TextBlock Text="화면에 등장할 강아지" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TxtSubBrush}" Margin="0,0,0,8"/>
                                <CheckBox x:Name="DogBreedCorgi"  Content="🍞 식빵 코기"
                                          Tag="Corgi"  Margin="0,2"
                                          Checked="DogBreed_Toggled" Unchecked="DogBreed_Toggled"/>
                                <CheckBox x:Name="DogBreedBichon" Content="☁️ 구름 비숑"
                                          Tag="Bichon" Margin="0,2"
                                          Checked="DogBreed_Toggled" Unchecked="DogBreed_Toggled"/>
                                <CheckBox x:Name="DogBreedGolden" Content="🍮 골든 리트리버"
                                          Tag="Golden" Margin="0,2"
                                          Checked="DogBreed_Toggled" Unchecked="DogBreed_Toggled"/>
                                <CheckBox x:Name="DogBreedPoodle" Content="🍫 초코 푸들"
                                          Tag="Poodle" Margin="0,2"
                                          Checked="DogBreed_Toggled" Unchecked="DogBreed_Toggled"/>
                                <Border Height="1" Background="{DynamicResource BorderBrushBase}" Margin="0,8,0,6"/>
                                <Button Content="모두 선택" Style="{StaticResource BtnGhost}"
                                        FontSize="11" Padding="10,4"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Click="DogBreedAll_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Button x:Name="AppIconSettingsBtn"
                            Content="{StaticResource ChromeIconSettings}"
                            ToolTip="앱 아이콘 설정"
                            Style="{StaticResource ChromeBtn}"
                            Click="AppIconSettingsBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="ThemeToggleBtn"
                            Content="{StaticResource ChromeIconThemeDark}"
                            ToolTip="테마 전환 (다크 ↔ 강아지)"
                            Style="{StaticResource ChromeBtn}"
                            Click="ThemeToggleBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="TopMostBtn"
                            Content="{StaticResource ChromeIconTopmost}"
                            ToolTip="항상 위에 고정 (전역)"
                            Style="{StaticResource ChromeBtn}"
                            Click="TopMostBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MinBtn"
                            Content="{StaticResource ChromeIconMin}"
                            ToolTip="최소화"
                            Style="{StaticResource ChromeBtn}"
                            Click="MinBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MaxBtn"
                            Content="{StaticResource ChromeIconMax}"
                            ToolTip="최대화"
                            Style="{StaticResource ChromeBtn}"
                            Click="MaxBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="CloseBtn"
                            Content="{StaticResource ChromeIconClose}"
                            ToolTip="닫기"
                            Style="{StaticResource ChromeCloseBtn}"
                            Click="CloseBtn_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dog animation overlay — transparent canvas, non-hit-testing, on top of everything -->
        <Canvas x:Name="DogAnimCanvas" Grid.Row="0" Grid.RowSpan="3"
                IsHitTestVisible="False" Visibility="Collapsed"
                Panel.ZIndex="20"/>

        <!-- Dog theme sitting-dog watermark (bottom-right, behind tab content) -->
        <Image x:Name="DogWatermark" Grid.Row="1"
               Source="{DynamicResource SittingDogWatermark}"
               Width="170" Height="170"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Margin="0,0,16,16"
               IsHitTestVisible="False" Visibility="Collapsed"
               Panel.ZIndex="0"/>

        <TabControl Grid.Row="1" x:Name="MainTabs" Background="{StaticResource BgBaseBrush}" BorderThickness="0" Padding="0"
                    Panel.ZIndex="1"
                    SelectedIndex="1"
                    SelectionChanged="MainTabs_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="{StaticResource BgBaseBrush}"/>
                    <Setter Property="Margin" Value="14,6,14,0"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="📊 대시보드" Style="{StaticResource DarkTabItem}">
              <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 0 header -->
                    <RowDefinition Height="Auto"/>   <!-- 1 hero tiles -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>   <!-- 3 health -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>      <!-- 5 trend + top models -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="대시보드" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TxtHighlight}" VerticalAlignment="Center"/>

                    <!-- Update notification button (hidden by default) -->
                    <Button Grid.Column="1" x:Name="UpdateBtn" Visibility="Collapsed"
                            Click="UpdateBtn_Click" Cursor="Hand" Margin="0,0,8,0"
                            BorderThickness="0" Padding="10,5">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{StaticResource AccentBgBrush}" CornerRadius="6"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="UpdateBtnIcon" Text="⬆" FontSize="12" Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="UpdateBtnText" Text="업데이트 가능" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBgHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="2" x:Name="CheckUpdateBtn"
                            Click="CheckUpdateBtn_Click" Margin="0,0,8,0"
                            Cursor="Hand" BorderThickness="0" Padding="0"
                            Background="Transparent" Foreground="{StaticResource TxtBrush}"
                            FontSize="12" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{StaticResource BgHoverBrush}"
                                        BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1"
                                        CornerRadius="4" ClipToBounds="True">
                                    <Grid>
                                        <Border x:Name="ProgressFill"
                                                HorizontalAlignment="Left"
                                                Background="{StaticResource AccentBrush}"
                                                Opacity="0.28"
                                                Width="0"/>
                                        <TextBlock x:Name="CheckUpdateBtnText"
                                                   Text="🔄 업데이트"
                                                   Padding="14,6"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource BgActiveBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Grid.Column="3" x:Name="GlobalRefreshBtn" Content="↻ 새로고침"
                            Style="{StaticResource Btn}" Click="GlobalRefreshBtn_Click"/>
                </Grid>

                <!-- ═══════════ Row 1: HERO 3-tile (Today / Month / Projected) ═══════════ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TODAY -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="💰 " FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="TODAY" Style="{StaticResource Sec}" Margin="0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" x:Name="HeroTodayCost" Text="$0.00"
                                       Style="{StaticResource Big}" FontSize="28" Margin="0,6,0,4"/>
                            <TextBlock Grid.Row="2" x:Name="HeroTodayDelta" Text="vs yesterday: --"
                                       FontSize="11" Foreground="{StaticResource TxtSub}"/>
                        </Grid>
                    </Border>

                    <!-- THIS MONTH -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="📊 " FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="THIS MONTH" Style="{StaticResource Sec}" Margin="0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" x:Name="HeroMonthCost" Text="$0.00"
                                       Style="{StaticResource Big}" FontSize="28" Margin="0,6,0,6"/>
                            <Grid Grid.Row="2" Height="6" Margin="0,0,0,6">
                                <Border Background="{StaticResource BorderBrushBase}" CornerRadius="3"/>
                                <Border x:Name="HeroMonthBarFill" Background="{StaticResource AccentBrush}"
                                        CornerRadius="3" HorizontalAlignment="Left" Width="0"/>
                            </Grid>
                            <TextBlock Grid.Row="3" x:Name="HeroMonthSub"
                                       Text="no budget set · -- days left"
                                       FontSize="11" Foreground="{StaticResource TxtSub}"/>
                        </Grid>
                    </Border>

                    <!-- PROJECTED -->
                    <Border Grid.Column="4" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="🔮 " FontSize="9" VerticalAlignment="Center"/>
                                <TextBlock Text="PROJECTED EOM" Style="{StaticResource Sec}" Margin="0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" x:Name="HeroProjectedCost" Text="$0.00"
                                       Style="{StaticResource Big}" FontSize="28" Margin="0,6,0,4"/>
                            <TextBlock Grid.Row="2" x:Name="HeroProjectedSub"
                                       Text="based on -- per day"
                                       FontSize="11" Foreground="{StaticResource TxtSub}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══════════ Row 3: Health (Claude | OpenAI | Gemini) ═══════════ -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Claude quota — Claude CLI 탭의 5h 세션 카드와 동일한 가로 막대 + 시간 마커 패턴 -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>     <!-- Header -->
                                <RowDefinition Height="Auto"/>     <!-- Session big numbers -->
                                <RowDefinition Height="Auto"/>     <!-- Session bar+marker -->
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>     <!-- Weekly big numbers -->
                                <RowDefinition Height="Auto"/>     <!-- Weekly bar+marker -->
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <ContentControl Style="{StaticResource ClaudeBrandIcon}"
                                                Width="11" Height="11" Margin="0,0,6,0"
                                                VerticalAlignment="Center"/>
                                <TextBlock Text="CLAUDE CLI · QUOTA" Style="{StaticResource Sec}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </StackPanel>

                            <!-- ─── Session row ─── -->
                            <Grid Grid.Row="1" Margin="0,0,0,26">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="5-HOUR SESSION  " FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TxtSubBrush}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ClaudeSessionText" Text="--%"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="ClaudeSessionReset"
                                           Text="Resets in --" FontSize="10"
                                           Foreground="{StaticResource TxtHintBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </Grid>

                            <Grid Grid.Row="2" Height="38" VerticalAlignment="Center" x:Name="GSessionBarRoot">
                                <Grid Height="10" VerticalAlignment="Center">
                                    <Border Background="{StaticResource BorderBrushBase}" CornerRadius="5"/>
                                    <Border x:Name="GSessionBar" Background="{StaticResource AccentBrush}" CornerRadius="5"
                                            HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                                <Canvas x:Name="GSessionMarkerCanvas" ClipToBounds="False">
                                    <Grid x:Name="GSessionMarker" Canvas.Left="0" Canvas.Top="-3"
                                          Visibility="Collapsed">
                                        <Rectangle Width="2" Height="26"
                                                   Fill="{DynamicResource AccentBlueBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{DynamicResource AccentBlueBrush}"
                                                 VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{DynamicResource AccentBlueBrush}"
                                                 VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-3"/>
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                                                Margin="0,-18,0,0"
                                                Background="{DynamicResource AccentBlueBrush}"
                                                CornerRadius="3" Padding="4,1">
                                            <TextBlock x:Name="GSessionMarkerLabel" Text="--%"
                                                       FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Canvas>
                            </Grid>

                            <!-- ─── Weekly row ─── -->
                            <Grid Grid.Row="4" Margin="0,0,0,26">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <TextBlock Text="WEEKLY  " FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource TxtSubBrush}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ClaudeWeekText" Text="--%"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="ClaudeWeekReset"
                                           Text="Resets in --" FontSize="10"
                                           Foreground="{StaticResource TxtHintBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            </Grid>

                            <Grid Grid.Row="5" Height="38" VerticalAlignment="Center" x:Name="GWeekBarRoot">
                                <Grid Height="10" VerticalAlignment="Center">
                                    <Border Background="{StaticResource BorderBrushBase}" CornerRadius="5"/>
                                    <Border x:Name="GWeekBar" Background="{StaticResource AccentBrush}" CornerRadius="5"
                                            HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                                <Canvas x:Name="GWeekMarkerCanvas" ClipToBounds="False">
                                    <Grid x:Name="GWeekMarker" Canvas.Left="0" Canvas.Top="-3"
                                          Visibility="Collapsed">
                                        <Rectangle Width="2" Height="26"
                                                   Fill="{DynamicResource AccentBlueBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{DynamicResource AccentBlueBrush}"
                                                 VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                                        <Ellipse Width="6" Height="6"
                                                 Fill="{DynamicResource AccentBlueBrush}"
                                                 VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-3"/>
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                                                Margin="0,-18,0,0"
                                                Background="{DynamicResource AccentBlueBrush}"
                                                CornerRadius="3" Padding="4,1">
                                            <TextBlock x:Name="GWeekMarkerLabel" Text="--%"
                                                       FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- OpenAI · 비용 (Codex CLI + OpenAI API 합산) -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="◯ " FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OpenAiBrandBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="OPENAI · 비용" Style="{StaticResource Sec}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="오늘" FontSize="10" Foreground="{StaticResource TxtSubBrush}"/>
                                    <TextBlock x:Name="OpenAiTodayText" Text="$0.00"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TxtHighlight}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="이번 달" FontSize="10" Foreground="{StaticResource TxtSubBrush}"/>
                                    <TextBlock x:Name="OpenAiMonthText" Text="$0.00"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource TxtHighlight}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Grid.Row="2" x:Name="OpenAiBreakdown"
                                       Text="CLI $0.00 · API $0.00"
                                       FontSize="10" Foreground="{StaticResource TxtSubBrush}"
                                       Margin="0,0,0,8"/>
                            <Canvas Grid.Row="3" x:Name="OpenAiMiniCanvas"
                                    Height="40" ClipToBounds="True"
                                    Background="Transparent"
                                    SizeChanged="OpenAiMiniCanvas_SizeChanged"/>
                            <TextBlock Grid.Row="4" Text="최근 7일 추세"
                                       FontSize="9" Foreground="{StaticResource TxtHintBrush}"
                                       HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Gemini budgets -->
                    <Border Grid.Column="4" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <ContentControl Style="{StaticResource GeminiBrandIcon}"
                                                Width="11" Height="11" Margin="0,0,6,0"
                                                VerticalAlignment="Center"/>
                                <TextBlock Text="GEMINI · BUDGETS" Style="{StaticResource Sec}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </StackPanel>
                            <ItemsControl Grid.Row="1" x:Name="GeminiBudgetsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10" ToolTip="{Binding Tooltip}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Alias}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TxtHighlight}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding SpendText}"
                                                           FontSize="11" Foreground="{StaticResource TxtSub}"/>
                                            </Grid>
                                            <Grid Grid.Row="1" Height="6" Margin="0,4,0,3">
                                                <Border Background="{StaticResource BorderBrushBase}" CornerRadius="3"/>
                                                <Border Background="{Binding BarBrush}"
                                                        CornerRadius="3" HorizontalAlignment="Left"
                                                        Width="{Binding BarWidth}"/>
                                            </Grid>
                                            <TextBlock Grid.Row="2" Text="{Binding SubText}"
                                                       FontSize="10" Foreground="{StaticResource TxtHintBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Grid.Row="2" x:Name="GeminiBudgetsEmpty"
                                       Text="등록된 Gemini 계정이 없습니다."
                                       FontSize="11" Foreground="{StaticResource TxtHintBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══════════ Row 5: Trend (2/3) + Top Models (1/3) ═══════════ -->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 7-day line chart -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="120"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="7일 추세 · Gemini 모델별"
                                           Style="{StaticResource Sec}"/>
                                <TextBlock Grid.Column="1" x:Name="TrendTotalLabel" Text="$0.00"
                                           FontSize="11" Foreground="{StaticResource TxtSub}"/>
                            </Grid>
                            <StackPanel Grid.Row="1" x:Name="TrendLegend" Orientation="Horizontal"
                                        Margin="0,2,0,6"/>
                            <Canvas Grid.Row="2" x:Name="TrendCanvas" ClipToBounds="True"
                                    SizeChanged="TrendCanvas_SizeChanged"/>
                            <Grid Grid.Row="3" x:Name="TrendAxis" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TrendDay0" Grid.Column="0" Text="" FontSize="9"
                                           Foreground="{StaticResource TxtHintBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrendDay1" Grid.Column="1" Text="" FontSize="9"
                                           Foreground="{StaticResource TxtHintBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrendDay2" Grid.Column="2" Text="" FontSize="9"
                                           Foreground="{StaticResource TxtHintBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrendDay3" Grid.Column="3" Text="" FontSize="9"
                                           Foreground="{StaticResource TxtHintBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrendDay4" Grid.Column="4" Text="" FontSize="9"
                                           Foreground="{StaticResource TxtHintBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrendDay5" Grid.Column="5" Text="" FontSize="9"
                                           Foreground="{StaticResource TxtHintBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TrendDay6" Grid.Column="6" Text="" FontSize="9"
                                           Foreground="{StaticResource TxtHintBrush}" HorizontalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Top 3 models -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="TOP MODELS · THIS MONTH"
                                       Style="{StaticResource Sec}" Margin="0,0,0,8"/>
                            <ItemsControl Grid.Row="1" x:Name="TopModelsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10" ToolTip="{Binding Tooltip}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="8" Height="8"
                                                        CornerRadius="2" Background="{Binding ColorBrush}"
                                                        Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                           FontSize="11" Foreground="{StaticResource TxtHighlight}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding CostText}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource AccentBrush}"/>
                                            </Grid>
                                            <Grid Grid.Row="1" Margin="14,3,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid Grid.Column="0" Height="4"
                                                      VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <Border Background="{StaticResource BorderBrushBase}" CornerRadius="2"/>
                                                    <Border Background="{Binding ColorBrush}"
                                                            CornerRadius="2" HorizontalAlignment="Left"
                                                            Width="{Binding BarWidth}"/>
                                                </Grid>
                                                <TextBlock Grid.Column="1" Text="{Binding ShareText}"
                                                           FontSize="10" Foreground="{StaticResource TxtSub}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Grid.Row="2" x:Name="TopModelsEmpty"
                                       Text="이번 달 사용 기록이 없습니다."
                                       FontSize="11" Foreground="{StaticResource TxtHintBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </Grid>
                    </Border>
                </Grid>
              </Grid>
            </TabItem>

            <TabItem Style="{StaticResource DarkTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Style="{StaticResource ClaudeBrandIcon}"
                                        Width="12" Height="12" Margin="0,0,6,0"
                                        VerticalAlignment="Center"/>
                        <TextBlock Text="Claude CLI" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
              <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>      <!-- Header -->
                    <RowDefinition Height="Auto"/>      <!-- Hero row (content-sized — bar + sub-cards) -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="2*"/>        <!-- Weekly cards -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="3*"/>        <!-- Delta chart (확장) -->
                </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Claude CLI Usage" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TxtHighlight}" VerticalAlignment="Center"/>

            <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="4" Padding="8,3" Background="{StaticResource BgInputBrush}"
                    VerticalAlignment="Center">
                <TextBlock x:Name="StatusLabel" Text="Waiting for session key..." FontSize="11"
                           Foreground="{StaticResource TxtSub}" FontWeight="SemiBold"/>
            </Border>

            <Button Grid.Column="3" x:Name="OpenClaudeBtn"
                    Style="{StaticResource Btn}" Click="OpenClaudeBtn_Click" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <ContentControl Style="{StaticResource ClaudeBrandIcon}"
                                    Width="11" Height="11" Margin="0,0,6,0"
                                    VerticalAlignment="Center"/>
                    <TextBlock Text="Claude CLI" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4" x:Name="RefreshBtn" Content="↻ 새로고침"
                    Style="{StaticResource Btn}" Click="RefreshBtn_Click" Margin="0,0,8,0"/>

            <Button Grid.Column="5" x:Name="LoginBtn" Content="로그인"
                    Style="{StaticResource Btn}" Click="LoginBtn_Click"/>
        </Grid>

        <!-- ═══ HERO ROW: 5-Hour Session + Routine + Extra (3 cards in 1 line) ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>      <!-- Session (메인) -->
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1*"/>      <!-- Routine -->
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1*"/>      <!-- Extra -->
            </Grid.ColumnDefinitions>

            <!-- 5-Hour Session — single bar: usage fill + time marker overlay + burn pace footer -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>     <!-- 헤더 -->
                        <RowDefinition Height="Auto"/>     <!-- Big USAGE % + TIME LEFT -->
                        <RowDefinition Height="Auto"/>     <!-- Bar + 마커 -->
                        <RowDefinition Height="Auto"/>     <!-- 페이스 인디케이터 / Burn rate -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="5-HOUR SESSION" Style="{StaticResource Sec}"/>
                        <TextBlock x:Name="SessionResetAtLabel" Text="Resets at --"
                                   FontSize="10" Foreground="{StaticResource TxtSub}" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Big numbers row: USAGE % (left) + TIME LEFT (right).
                         Bottom margin 26 = 마커 배지가 바 위로 21px 떠 있어서 큰 숫자와 겹치지 않도록 확보 -->
                    <Grid Grid.Row="1" Margin="0,8,0,26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="USAGE  " FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TxtSub}" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                            <TextBlock x:Name="UsagePctText" Text="0%" FontSize="22"
                                       FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text=" / session" FontSize="10"
                                       Foreground="{StaticResource TxtHintBrush}"
                                       VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" VerticalAlignment="Bottom">
                            <Run x:Name="TimeLeftText" Text="--" FontSize="22"
                                 FontWeight="Bold" Foreground="{DynamicResource AccentBlueBrush}"/>
                            <Run x:Name="TimeLeftPctText" Text=" left" FontSize="10"
                                 Foreground="{StaticResource TxtHintBrush}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Combined bar: usage fill + time marker (flowing) -->
                    <Grid Grid.Row="2" Height="38" VerticalAlignment="Center" x:Name="SessionBarRoot">
                        <Grid Height="10" VerticalAlignment="Center">
                            <Border Background="{StaticResource BorderBrushBase}" CornerRadius="5"/>
                            <Border x:Name="UsageBar" Background="{StaticResource AccentBrush}" CornerRadius="5"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                        <Canvas x:Name="SessionTimeMarkerCanvas" ClipToBounds="False">
                            <Grid x:Name="SessionTimeMarker" Canvas.Left="0" Canvas.Top="-3"
                                  Visibility="Collapsed">
                                <Rectangle Width="2" Height="26"
                                           Fill="{DynamicResource AccentBlueBrush}"
                                           HorizontalAlignment="Center"/>
                                <Ellipse Width="6" Height="6"
                                         Fill="{DynamicResource AccentBlueBrush}"
                                         VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                                <Ellipse Width="6" Height="6"
                                         Fill="{DynamicResource AccentBlueBrush}"
                                         VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-3"/>
                                <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                                        Margin="0,-18,0,0"
                                        Background="{DynamicResource AccentBlueBrush}"
                                        CornerRadius="3" Padding="4,1">
                                    <TextBlock x:Name="SessionTimeMarkerLabel" Text="--%"
                                               FontSize="9" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Canvas>
                    </Grid>

                    <!-- 페이스 인디케이터: 사용 vs 시간 비교, 예상 종료 % 표시 -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="SessionPaceText"
                                   Text="—"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TxtSubBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="SessionBurnText"
                                   Text="—"
                                   FontSize="11" Foreground="{StaticResource TxtSubBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Daily Routine -->
            <Border Grid.Column="2" x:Name="RoutineCard" Style="{StaticResource Card}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="DAILY ROUTINES" Style="{StaticResource Sec}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="RoutineUsedText" Text="0" Style="{StaticResource Big}"/>
                        <TextBlock x:Name="RoutineLimitText" Text="/ 0" FontSize="12"
                                   Foreground="{StaticResource TxtSub}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                    </StackPanel>
                    <TextBlock x:Name="RoutineResetText" Text="Resets in --"
                               FontSize="10" Foreground="{StaticResource TxtSub}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Extra Usage -->
            <Border Grid.Column="4" x:Name="ExtraCard" Style="{StaticResource Card}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="EXTRA USAGE" Style="{StaticResource Sec}"/>
                    <TextBlock x:Name="ExtraUsedText" Text="$0.00" Style="{StaticResource Big}"/>
                    <TextBlock x:Name="ExtraLimitText" Text="of $0.00" FontSize="11"
                               Foreground="{StaticResource TxtSub}" Margin="0,2,0,8"/>
                    <Grid Height="6" Margin="0,0,0,6">
                        <Border Background="{StaticResource BorderBrushBase}" CornerRadius="3"/>
                        <Border x:Name="ExtraBar" Background="{StaticResource AccentBrush}" CornerRadius="3"
                                HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ExtraPctText" Text="0%" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource TxtHighlight}"/>
                        <TextBlock Text="  Monthly" FontSize="10" Foreground="{StaticResource TxtSub}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ExtraDisabledText" Text="Disabled" FontSize="11"
                               Foreground="{DynamicResource AccentRedBrush}" Visibility="Collapsed" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ WEEKLY CARDS ═══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- All Models -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="WEEKLY · ALL MODELS" Style="{StaticResource Sec}"/>
                    <!-- 큰 숫자 아래 24px = 시간 마커 배지(바 위 21px) 와 겹치지 않게 -->
                    <TextBlock Grid.Row="1" x:Name="WeekAllPctText" Text="0%" Style="{StaticResource Big}"
                               Margin="0,0,0,24"/>
                    <!-- 마커 라벨이 위로 18px 떠 있어야 하므로 행 높이 30 으로 확보 -->
                    <Grid Grid.Row="2" Height="30" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Grid Height="6" VerticalAlignment="Center">
                            <Border Background="{StaticResource BorderBrushBase}" CornerRadius="3"/>
                            <Border x:Name="WeekAllBar" Background="{StaticResource AccentBrush}" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                        <Canvas x:Name="WeekAllMarkerCanvas" ClipToBounds="False">
                            <Grid x:Name="WeekAllMarker" Canvas.Left="0" Canvas.Top="-2"
                                  Visibility="Collapsed">
                                <Rectangle Width="2" Height="22" Fill="{DynamicResource TxtHighlightBrush}" HorizontalAlignment="Center"/>
                                <Ellipse Width="5" Height="5" Fill="{DynamicResource TxtHighlightBrush}" VerticalAlignment="Top"
                                         HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                <Ellipse Width="5" Height="5" Fill="{DynamicResource TxtHighlightBrush}" VerticalAlignment="Bottom"
                                         HorizontalAlignment="Center" Margin="0,0,0,-2"/>
                                <!-- % 배지: 마커 상단에 항상 떠 있도록 VerticalAlignment+Margin 사용 (Canvas.Top 은 Grid 부모에서 무시됨) -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-18,0,0"
                                        Background="{DynamicResource TxtHighlightBrush}"
                                        CornerRadius="3" Padding="4,1">
                                    <TextBlock x:Name="WeekAllMarkerLabel" Text="--%"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource BgInputBrush}"/>
                                </Border>
                            </Grid>
                        </Canvas>
                    </Grid>
                    <TextBlock Grid.Row="3" x:Name="WeekAllResetText" Text="Resets in --"
                               FontSize="10" Foreground="{StaticResource TxtSub}"/>
                </Grid>
            </Border>

            <!-- Sub Model -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="SubModelTitle" Text="WEEKLY · SONNET"
                               Style="{StaticResource Sec}"/>
                    <TextBlock Grid.Row="1" x:Name="SubPctText" Text="0%" Style="{StaticResource Big}"
                               Margin="0,0,0,24"/>
                    <Grid Grid.Row="2" Height="30" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Grid Height="6" VerticalAlignment="Center">
                            <Border Background="{StaticResource BorderBrushBase}" CornerRadius="3"/>
                            <Border x:Name="SubBar" Background="{StaticResource AccentBrush}" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                        <Canvas x:Name="SubMarkerCanvas" ClipToBounds="False">
                            <Grid x:Name="SubMarker" Canvas.Left="0" Canvas.Top="-2"
                                  Visibility="Collapsed">
                                <Rectangle Width="2" Height="22" Fill="{DynamicResource TxtHighlightBrush}" HorizontalAlignment="Center"/>
                                <Ellipse Width="5" Height="5" Fill="{DynamicResource TxtHighlightBrush}" VerticalAlignment="Top"
                                         HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                <Ellipse Width="5" Height="5" Fill="{DynamicResource TxtHighlightBrush}" VerticalAlignment="Bottom"
                                         HorizontalAlignment="Center" Margin="0,0,0,-2"/>
                                <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-18,0,0"
                                        Background="{DynamicResource TxtHighlightBrush}"
                                        CornerRadius="3" Padding="4,1">
                                    <TextBlock x:Name="SubMarkerLabel" Text="--%"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource BgInputBrush}"/>
                                </Border>
                            </Grid>
                        </Canvas>
                    </Grid>
                    <TextBlock Grid.Row="3" x:Name="SubResetText" Text="Resets in --"
                               FontSize="10" Foreground="{StaticResource TxtSub}"/>
                </Grid>
            </Border>

            <!-- Claude Design -->
            <Border Grid.Column="4" x:Name="DesignCard" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="WEEKLY · CLAUDE DESIGN"
                               Style="{StaticResource Sec}"/>
                    <TextBlock Grid.Row="1" x:Name="DesignPctText" Text="0%" Style="{StaticResource Big}"
                               Margin="0,0,0,24"/>
                    <Grid Grid.Row="2" Height="30" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Grid Height="6" VerticalAlignment="Center">
                            <Border Background="{StaticResource BorderBrushBase}" CornerRadius="3"/>
                            <Border x:Name="DesignBar" Background="{StaticResource AccentBrush}" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Grid>
                        <Canvas x:Name="DesignMarkerCanvas" ClipToBounds="False">
                            <Grid x:Name="DesignMarker" Canvas.Left="0" Canvas.Top="-2"
                                  Visibility="Collapsed">
                                <Rectangle Width="2" Height="22" Fill="{DynamicResource TxtHighlightBrush}" HorizontalAlignment="Center"/>
                                <Ellipse Width="5" Height="5" Fill="{DynamicResource TxtHighlightBrush}" VerticalAlignment="Top"
                                         HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                                <Ellipse Width="5" Height="5" Fill="{DynamicResource TxtHighlightBrush}" VerticalAlignment="Bottom"
                                         HorizontalAlignment="Center" Margin="0,0,0,-2"/>
                                <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-18,0,0"
                                        Background="{DynamicResource TxtHighlightBrush}"
                                        CornerRadius="3" Padding="4,1">
                                    <TextBlock x:Name="DesignMarkerLabel" Text="--%"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource BgInputBrush}"/>
                                </Border>
                            </Grid>
                        </Canvas>
                    </Grid>
                    <TextBlock Grid.Row="3" x:Name="DesignResetText" Text="Resets in --"
                               FontSize="10" Foreground="{StaticResource TxtSub}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ DELTA CHART ═══ -->
        <Border Grid.Row="5" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SESSION USAGE DELTA · REALTIME"
                           Style="{StaticResource Sec}"/>
                <Canvas x:Name="DeltaChartCanvas" Grid.Row="1"
                        SizeChanged="DeltaChartCanvas_SizeChanged" ClipToBounds="True"/>
                <TextBlock x:Name="DeltaEmptyText" Grid.Row="1"
                           Text="Collecting data... 0 snapshot(s) so far"
                           FontSize="11" Foreground="{StaticResource TxtSub}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

              </Grid>
            </TabItem>

            <!-- ═══ CLAUDE API TAB (v2.6.0) ═══ -->
            <TabItem Style="{StaticResource DarkTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Style="{StaticResource ClaudeBrandIcon}"
                                        Width="12" Height="12" Margin="0,0,6,0"
                                        VerticalAlignment="Center"/>
                        <TextBlock Text="Claude API" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Claude API Usage" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource TxtHighlight}" VerticalAlignment="Center"/>

                        <Border Grid.Column="2" CornerRadius="6" Background="{StaticResource BgInputBrush}"
                                BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" Padding="4"
                                HorizontalAlignment="Left" VerticalAlignment="Center" MinWidth="260">
                            <ComboBox x:Name="AnthropicAccountCombo"
                                      Background="Transparent"
                                      BorderThickness="0" FontSize="12" Padding="8,4"
                                      SelectionChanged="AnthropicAccountCombo_SelectionChanged"/>
                        </Border>

                        <Button Grid.Column="3" x:Name="AnthropicAddAccountBtn" Content="+ 계정 추가"
                                Style="{StaticResource Btn}" Click="AnthropicAddAccountBtn_Click"
                                Margin="8,0,6,0"/>
                        <Button Grid.Column="4" x:Name="AnthropicRefreshBtn" Content="↻ 새로고침"
                                Style="{StaticResource Btn}" Click="AnthropicRefreshBtn_Click"
                                Margin="0,0,6,0"/>
                        <Button Grid.Column="5" x:Name="AnthropicRemoveBtn" Content="🗑 제거"
                                Style="{StaticResource Btn}" Click="AnthropicRemoveBtn_Click"/>
                    </Grid>

                    <Grid Grid.Row="1" x:Name="AnthropicContent">
                        <StackPanel x:Name="AnthropicEmptyState" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <ContentControl Style="{StaticResource ClaudeBrandIcon}"
                                            Width="56" Height="56" HorizontalAlignment="Center"
                                            Margin="0,0,0,12"/>
                            <TextBlock Text="Anthropic API 계정이 등록되지 않았습니다"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TxtHighlight}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Admin API Key (sk-ant-admin*)를 등록하여 사용량을 조회하세요"
                                       FontSize="11" Foreground="{StaticResource TxtSub}"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <Button Content="+ 첫 계정 추가하기" Style="{StaticResource Btn}"
                                    Click="AnthropicAddAccountBtn_Click" HorizontalAlignment="Center"
                                    Padding="22,8"/>
                        </StackPanel>

                        <Grid x:Name="AnthropicDashboard" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ACTIVE ACCOUNT" Style="{StaticResource Sec}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="AnthropicActiveAlias" Text="--"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource TxtHighlight}"/>
                                            <TextBlock x:Name="AnthropicActiveKeyPreview" Text=""
                                                       FontSize="11" Foreground="{StaticResource TxtSub}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="AnthropicActiveOrg" Text=""
                                                   FontSize="10" Foreground="{StaticResource TxtHintBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="조회 기간" FontSize="10" Foreground="{StaticResource TxtSub}"
                                                   HorizontalAlignment="Right"/>
                                        <ComboBox x:Name="AnthropicRangeCombo" Width="120"
                                                  SelectionChanged="AnthropicRangeCombo_SelectionChanged">
                                            <ComboBoxItem Content="오늘" Tag="1"/>
                                            <ComboBoxItem Content="7일" Tag="7" IsSelected="True"/>
                                            <ComboBoxItem Content="30일" Tag="30"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="TOTAL COST" Style="{StaticResource Sec}"/>
                                        <TextBlock x:Name="AnthropicTotalCost" Text="$0.00"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtHighlight}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="INPUT TOKENS" Style="{StaticResource Sec}"/>
                                        <TextBlock x:Name="AnthropicTotalInput" Text="0"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtHighlight}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="OUTPUT TOKENS" Style="{StaticResource Sec}"/>
                                        <TextBlock x:Name="AnthropicTotalOutput" Text="0"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtHighlight}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="CACHE TOKENS" Style="{StaticResource Sec}"/>
                                        <TextBlock x:Name="AnthropicTotalCache" Text="0"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtHighlight}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="4" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="MODEL BREAKDOWN" Style="{StaticResource Sec}"
                                               Margin="0,0,0,8"/>
                                    <DataGrid Grid.Row="1" x:Name="AnthropicModelGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True" HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              Background="Transparent" BorderThickness="0" RowBackground="Transparent"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              CanUserResizeRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                                            <DataGridTextColumn Header="Input" Binding="{Binding InputDisplay}" Width="100"/>
                                            <DataGridTextColumn Header="Output" Binding="{Binding OutputDisplay}" Width="100"/>
                                            <DataGridTextColumn Header="Cache W" Binding="{Binding CacheWriteDisplay}" Width="100"/>
                                            <DataGridTextColumn Header="Cache R" Binding="{Binding CacheReadDisplay}" Width="100"/>
                                            <DataGridTextColumn Header="Cost" Binding="{Binding CostDisplay}" Width="100"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="AnthropicStatusLabel" Grid.Row="4"
                                       VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                       Margin="0,0,8,8" FontSize="10" Foreground="{StaticResource TxtSub}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource DarkTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ContentControl Style="{StaticResource GeminiBrandIcon}"
                                        Width="12" Height="12" Margin="0,0,6,0"
                                        VerticalAlignment="Center"/>
                        <TextBlock Text="Gemini API" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
              <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header + Account Switcher -->
                    <RowDefinition Height="*"/>      <!-- Content -->
                </Grid.RowDefinitions>

                <!-- Gemini Header -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Gemini API Usage" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TxtHighlight}" VerticalAlignment="Center"/>

                    <!-- Account switcher -->
                    <Border Grid.Column="2" CornerRadius="6" Background="{StaticResource BgInputBrush}"
                            BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" Padding="4"
                            HorizontalAlignment="Left" VerticalAlignment="Center" MinWidth="260">
                        <ComboBox x:Name="GeminiAccountCombo"
                                  Background="Transparent"
                                  BorderThickness="0" FontSize="12" Padding="8,4"
                                  SelectionChanged="GeminiAccountCombo_SelectionChanged"/>
                    </Border>

                    <Button Grid.Column="3" x:Name="GeminiAddAccountBtn" Content="+ 계정 추가"
                            Style="{StaticResource Btn}" Click="GeminiAddAccountBtn_Click"
                            Margin="8,0,6,0"/>
                    <Button Grid.Column="4" x:Name="GeminiExportBtn" Content="⭳ 내보내기"
                            Style="{StaticResource Btn}" Click="GeminiExportBtn_Click"
                            Margin="0,0,6,0"/>
                    <Button Grid.Column="5" x:Name="GeminiPricingBtn" Content="$ 단가"
                            Style="{StaticResource Btn}" Click="GeminiPricingBtn_Click"
                            Margin="0,0,6,0"/>
                    <Button Grid.Column="6" x:Name="GeminiManageBtn" Content="⚙ 관리"
                            Style="{StaticResource Btn}" Click="GeminiManageBtn_Click"/>
                </Grid>

                <!-- Gemini Content -->
                <Grid Grid.Row="1" x:Name="GeminiContent">
                    <!-- Empty state -->
                    <StackPanel x:Name="GeminiEmptyState" VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <ContentControl Style="{StaticResource GeminiBrandIcon}"
                                        Width="56" Height="56" HorizontalAlignment="Center"
                                        Margin="0,0,0,12"/>
                        <TextBlock Text="Gemini 계정이 등록되지 않았습니다"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TxtHighlight}"
                                   HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Google AI Studio API Key를 등록하여 사용량을 추적하세요"
                                   FontSize="11" Foreground="{StaticResource TxtSub}"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <Button Content="+ 첫 계정 추가하기" Style="{StaticResource Btn}"
                                Click="GeminiAddAccountBtn_Click" HorizontalAlignment="Center"
                                Padding="22,8"/>
                    </StackPanel>

                    <!-- Dashboard (shown when account exists) -->
                    <Grid x:Name="GeminiDashboard" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Active account info bar -->
                        <Border Grid.Row="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ACTIVE ACCOUNT" Style="{StaticResource Sec}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="GeminiActiveAlias" Text="--"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource TxtHighlight}"/>
                                        <TextBlock x:Name="GeminiActiveKeyPreview" Text=""
                                                   FontSize="11" Foreground="{StaticResource TxtSub}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" x:Name="GeminiStatusLabel"
                                           Text="대기 중" FontSize="11" Foreground="{StaticResource TxtSub}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                                <Button Grid.Column="2" x:Name="GeminiTestBtn" Content="🔌 연결 테스트"
                                        Style="{StaticResource Btn}" Click="GeminiTestBtn_Click"
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="3" x:Name="GeminiRefreshBtn" Content="↻ 새로고침"
                                        Style="{StaticResource Btn}" Click="GeminiRefreshBtn_Click"/>
                            </Grid>
                        </Border>

                        <!-- Usage summary cards -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- 0 LOCAL RELAY (entry point — must be running for tracking) -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>   <!-- 2 Summary -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>   <!-- 4 Cost by account -->
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>      <!-- 6 Recent usage -->
                            </Grid.RowDefinitions>

                            <!-- Summary row -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="TODAY · TOKENS" Style="{StaticResource Sec}"/>
                                        <TextBlock x:Name="GeminiTodayTokens" Text="0"
                                                   Style="{StaticResource Big}"/>
                                        <TextBlock Text="input + output" FontSize="10"
                                                   Foreground="{StaticResource TxtSub}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource Card}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="TODAY · COST" Style="{StaticResource Sec}"/>
                                        <TextBlock x:Name="GeminiTodayCost" Text="$0.00"
                                                   Style="{StaticResource Big}"/>
                                        <TextBlock Text="estimated" FontSize="10"
                                                   Foreground="{StaticResource TxtSub}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Style="{StaticResource Card}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="REQUESTS · 24H" Style="{StaticResource Sec}"/>
                                        <TextBlock x:Name="GeminiRequestCount" Text="0"
                                                   Style="{StaticResource Big}"/>
                                        <TextBlock x:Name="GeminiLastCallText" Text="no calls yet"
                                                   FontSize="10" Foreground="{StaticResource TxtSub}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Accounts comparison (today cost) -->
                            <Border Grid.Row="4" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="오늘 · 계정별 사용 비용"
                                               Style="{StaticResource Sec}"/>
                                    <ItemsControl Grid.Row="1" x:Name="GeminiCompareList" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="90"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                               FontSize="11" Foreground="{StaticResource TxtHighlight}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Grid Grid.Column="1" Height="10" VerticalAlignment="Center"
                                                          Margin="4,0">
                                                        <Border Background="{StaticResource BorderBrushBase}" CornerRadius="5"/>
                                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="5"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding BarWidth}"/>
                                                    </Grid>
                                                    <TextBlock Grid.Column="2" Text="{Binding CostText}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>

                            <!-- Local Relay (moved to top — entry point for tracking) -->
                            <Border Grid.Row="0" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>     <!-- 0 헤더 -->
                                        <RowDefinition Height="Auto"/>     <!-- 1 'What is this?' Expander -->
                                        <RowDefinition Height="Auto"/>     <!-- 2 컨트롤 -->
                                        <RowDefinition Height="Auto"/>     <!-- 3 사용법 한 줄 -->
                                        <RowDefinition Height="Auto"/>     <!-- 4 활성 클라이언트 -->
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="LOCAL RELAY (PoC)"
                                                   Style="{StaticResource Sec}"/>
                                        <TextBlock Grid.Column="1" x:Name="GeminiRelayStatusText"
                                                   Text="● Stopped" FontSize="11" Foreground="{StaticResource TxtSub}"
                                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" x:Name="GeminiRelayStatsText"
                                                   Text="" FontSize="10" Foreground="{StaticResource TxtHintBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- '이게 뭔가요?' 펼침 박스 — 처음 보는 사용자만 클릭해서 확인하면 됨 -->
                                    <Expander Grid.Row="1" Margin="0,8,0,0"
                                              Foreground="{StaticResource TxtSubBrush}">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource RelayIconBulb}"
                                                      Fill="{DynamicResource AccentBrush}"
                                                      Width="11" Height="11" Stretch="Uniform"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="Gemini Local Relay 가 뭔가요?"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TxtBrush}"/>
                                            </StackPanel>
                                        </Expander.Header>
                                        <Border Background="{StaticResource AccentBgBrush}"
                                                BorderBrush="{StaticResource AccentBrush}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="12,10" Margin="0,8,0,4">
                                            <StackPanel>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TxtBrush}"
                                                           TextWrapping="Wrap">
                                                    <Run FontWeight="SemiBold">한 줄 요약 ·</Run>
                                                    <Run>외부 프로그램의 Gemini API 호출을 가운데서 가로채 토큰·비용을 자동 기록하는 로컬 HTTP 서버.</Run>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TxtSubBrush}"
                                                           TextWrapping="Wrap" Margin="0,8,0,0">
                                                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">왜 쓰나요?</Run>
                                                    <LineBreak/>
                                                    <Run>다른 프로그램·SDK·스크립트가 Gemini 를 호출하는데 사용량을 따로 집계하기 어려울 때, 그 트래픽이 이 트래커를 한 번 거쳐 가게 하면 모든 호출의 토큰 수와 비용이 자동으로 대시보드에 기록됩니다. SDK 코드는 한 줄도 안 고쳐도 됩니다.</Run>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TxtSubBrush}"
                                                           TextWrapping="Wrap" Margin="0,8,0,0">
                                                    <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">어떻게 동작하나요?</Run>
                                                    <LineBreak/>
                                                    <Run>외부 프로그램의 base URL 을</Run>
                                                    <Run FontFamily="Consolas" Foreground="{StaticResource TxtBrush}">http://127.0.0.1:47821</Run>
                                                    <Run>로, API 키를</Run>
                                                    <Run FontFamily="Consolas" Foreground="{StaticResource AccentYellowBrush}">tracker-&lt;alias&gt;</Run>
                                                    <Run>처럼 placeholder 로 둡니다. 트래커가 받자마자 저장된 진짜 키로 바꿔 Google 로 전달하므로, 외부 코드에는 진짜 키가 절대 노출되지 않습니다.</Run>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="{StaticResource TxtHintBrush}"
                                                           TextWrapping="Wrap" Margin="0,8,0,0">
                                                    💡 ⚙ 설정 버튼을 누르면 PowerShell · cURL · Python · Node.js 용 자동 적용 스니펫과 단계별 가이드가 열립니다.
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Expander>

                                    <Grid Grid.Row="2" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="Port"
                                                   FontSize="11" Foreground="{StaticResource TxtSub}"
                                                   VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="2" x:Name="GeminiRelayPortBox"
                                                 Width="70" Padding="6,3" FontSize="12"
                                                 Background="{StaticResource BgInputBrush}" Foreground="{StaticResource TxtHighlight}"
                                                 BorderBrush="{StaticResource BorderBrushBase}" CaretBrush="{StaticResource AccentBrush}"
                                                 Text="47821"/>

                                        <CheckBox Grid.Column="4" x:Name="GeminiRelayAutoStartCheck"
                                                  Content="앱 시작 시 자동 실행"
                                                  FontSize="11" Foreground="{StaticResource TxtSub}"
                                                  VerticalAlignment="Center"
                                                  Checked="GeminiRelayAutoStart_Changed"
                                                  Unchecked="GeminiRelayAutoStart_Changed"/>

                                        <Button Grid.Column="6" x:Name="GeminiRelayStartBtn"
                                                Content="▶ 시작" Style="{StaticResource BtnPrimary}"
                                                Click="GeminiRelayStartBtn_Click" MinWidth="80"/>
                                        <Button Grid.Column="8" x:Name="GeminiRelayCopyBtn"
                                                Content="⚙ 설정" Style="{StaticResource Btn}"
                                                Click="GeminiRelayCopyBtn_Click" MinWidth="100"/>
                                    </Grid>

                                    <TextBlock Grid.Row="3" x:Name="GeminiRelayHelpText"
                                               FontSize="10" Foreground="{StaticResource TxtHintBrush}" Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Text="시작 후, 다른 프로그램/SDK의 base URL을 http://127.0.0.1:47821 로, API 키를 'tracker-&lt;alias&gt;' (예: tracker-default)로 설정하세요. 모든 호출이 이 대시보드에 집계됩니다."/>

                                    <!-- 활성 클라이언트 리스트 (최근 5분 내 접속) -->
                                    <Border Grid.Row="4" x:Name="GeminiRelayClientsBox"
                                            Background="{StaticResource BgInputBrush}"
                                            BorderBrush="{StaticResource BorderBrushBase}"
                                            BorderThickness="1" CornerRadius="6"
                                            Padding="10,8" Margin="0,8,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="GeminiRelayClientsTitle"
                                                       Text="👥 ACTIVE CLIENTS"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TxtSubBrush}" Margin="0,0,0,4"/>
                                            <ItemsControl x:Name="GeminiRelayClientsList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Title}"
                                                                       FontSize="11" Foreground="{StaticResource TxtBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Stats}"
                                                                       FontSize="10" Foreground="{StaticResource TxtHintBrush}"
                                                                       Margin="10,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding LastSeen}"
                                                                       FontSize="10" Foreground="{StaticResource AccentBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Usage history list -->
                            <Border Grid.Row="6" Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="RECENT USAGE (this account)"
                                               Style="{StaticResource Sec}"/>

                                    <Grid Grid.Row="1" Margin="0,6,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="TIME" FontSize="9" Foreground="{StaticResource TxtHintBrush}"/>
