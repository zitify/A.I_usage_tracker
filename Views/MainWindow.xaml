                                   Foreground="{DynamicResource AccentRedBrush}" Visibility="Collapsed" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ WEEKLY CARDS ═══ -->
