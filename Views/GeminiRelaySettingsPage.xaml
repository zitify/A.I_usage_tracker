<UserControl x:Class="AIUsageTracker.Views.GeminiRelaySettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBaseBrush}">

    <UserControl.Resources>
        <!-- Code-display TextBox (read-only, monospace, slightly darker surface
             — kept local because the design system has no dedicated 'code' token) -->
        <Style x:Key="CodeBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgBaseBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TxtBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushBase}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas, 'Courier New'"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        </Style>

        <Style x:Key="SecTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ExpanderHeaderTB" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TxtBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header bar -->
        <Border Grid.Row="0" Background="{StaticResource BgTitleBarBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← 뒤로" Style="{StaticResource BtnGhost}"
                        Click="Back_Click"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource RelayIconAntenna}"
                          Fill="{DynamicResource TxtHighlightBrush}"
                          Width="14" Height="14" Stretch="Uniform"
                          VerticalAlignment="Center" Margin="0,0,8,0"
                          SnapsToDevicePixels="True"/>
                    <TextBlock Text="Gemini Local Relay" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TxtHighlightBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SubtitleText" Text="" FontSize="11" Foreground="{StaticResource TxtSubBrush}"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14,18,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Info box (uses accent surface from design system) -->
                <Border Grid.Row="0" Background="{StaticResource AccentBgBrush}"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Data="{StaticResource RelayIconBulb}"
                              Fill="{DynamicResource AccentBrush}"
                              Width="14" Height="14" Stretch="Uniform"
                              VerticalAlignment="Top" Margin="0,2,8,0"
                              SnapsToDevicePixels="True"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="12" Foreground="{StaticResource TxtBrush}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">동작 방식:</Run>
                                <Run>다른 프로그램/SDK가 Gemini API 대신 이 트래커를 바라보게 설정하면, 트래커가 중계하면서 모든 호출의 토큰·비용을 자동 기록합니다.</Run>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{StaticResource TxtHintBrush}" TextWrapping="Wrap" Margin="0,6,0,0">
                                <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">Placeholder 키 규칙:</Run>
                                <Run>실제 API 키 대신</Run>
                                <Run FontFamily="Consolas" Foreground="{StaticResource AccentYellowBrush}">tracker-&lt;alias&gt;</Run>
                                <Run>를 사용합니다. 트래커가 저장된 실제 키로 치환해서 전송하므로, 외부 클라이언트에 진짜 키가 절대 노출되지 않습니다.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Auto-setup cards container -->
                <StackPanel Grid.Row="2">

                <!-- Env var auto-apply card (Step 1) -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Path Data="{StaticResource RelayIconTarget}"
                                  Fill="{DynamicResource AccentBlueBrush}"
                                  Width="13" Height="13" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                  SnapsToDevicePixels="True"/>
                            <TextBlock Text="1단계 · 환경변수 자동 설정" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   FontSize="11" Foreground="{StaticResource TxtSubBrush}" TextWrapping="Wrap"
                                   Margin="0,4,0,10">
                            <Run>환경변수 4개</Run>
                            <Run FontFamily="Consolas" Foreground="{StaticResource TxtBrush}">GOOGLE_API_KEY, GEMINI_API_KEY, GOOGLE_GENAI_BASE_URL, GOOGLE_GEMINI_BASE_URL</Run>
                            <Run>을 이 PC의 사용자 계정에 설정/제거합니다. 앞으로 새로 열리는 모든 터미널·IDE·스크립트에 자동 반영됩니다.</Run>
                        </TextBlock>

                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="StatusBadgeText" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="PrimaryActionBtn"
                                    Style="{StaticResource BtnPrimary}"
                                    Click="PrimaryAction_Click" MinWidth="140">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource BtnIconPath}"
                                          Data="{StaticResource RelayIconBolt}"/>
                                    <TextBlock x:Name="PrimaryActionLabel" Text="자동 설정" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RevertBtn"
                                    Style="{StaticResource BtnDanger}"
                                    Click="Revert_Click" MinWidth="120" Margin="8,0,0,0"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource BtnIconPath}"
                                          Data="{StaticResource RelayIconRefresh}"/>
                                    <TextBlock Text="되돌리기" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   FontSize="10" Foreground="{StaticResource TxtSubBrush}" TextWrapping="Wrap"
                                   Margin="0,10,0,0">
                            <Run>ⓘ 이미 열려 있는 터미널/IDE는 재시작해야 새 값을 인식합니다. 기존 사용자 값이 있으면 자동으로 백업되고, 되돌리기 시 복원됩니다.</Run>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Claude CLI rule card (Step 2) -->
                <Border Style="{StaticResource Card}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Path Data="{StaticResource RelayIconRule}"
                                  Fill="{DynamicResource AccentBlueBrush}"
                                  Width="13" Height="13" Stretch="Uniform"
                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                  SnapsToDevicePixels="True"/>
                            <TextBlock Text="2단계 · Claude CLI 연동 규칙 설치" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   FontSize="11" Foreground="{StaticResource TxtSubBrush}" TextWrapping="Wrap"
                                   Margin="0,4,0,10">
                            <Run>사용자 프로필의</Run>
                            <Run FontFamily="Consolas" Foreground="{StaticResource TxtBrush}">~/.claude/CLAUDE.md</Run>
                            <Run>에 규칙 블록을 추가합니다. 설치 후에는 Claude CLI 세션에서</Run>
                            <Run FontStyle="Italic" Foreground="{StaticResource TxtBrush}">"재미나이로 X해줘"</Run>
                            <Run>라고 말하면 자동으로 Gemini 2.5 Flash/Pro를 호출하고, 응답을 받아 작업을 이어갑니다.</Run>
                        </TextBlock>

                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="RuleStatusBadgeText" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="InstallRuleBtn"
                                    Style="{StaticResource BtnPrimary}"
                                    Click="InstallRule_Click" MinWidth="140">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource BtnIconPath}"
                                          Data="{StaticResource RelayIconBolt}"/>
                                    <TextBlock x:Name="InstallRuleLabel" Text="규칙 설치" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RemoveRuleBtn"
                                    Style="{StaticResource BtnDanger}"
                                    Click="RemoveRule_Click" MinWidth="120" Margin="8,0,0,0"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource BtnIconPath}"
                                          Data="{StaticResource RelayIconRefresh}"/>
                                    <TextBlock Text="제거" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   FontSize="10" Foreground="{StaticResource TxtSubBrush}" TextWrapping="Wrap"
                                   Margin="0,10,0,0">
                            <Run>ⓘ 이미 실행 중인 Claude CLI 세션은 변경을 인식하지 않습니다. 세션 종료 후 새로 시작한 claude 부터 규칙이 적용됩니다. 사용자가 수동 편집한 다른 부분은 건드리지 않습니다.</Run>
                        </TextBlock>
                    </Grid>
                </Border>

                </StackPanel>

                <!-- Advanced (expanders) -->
                <StackPanel Grid.Row="4">

                    <Expander Margin="0,0,0,10" IsExpanded="False" Foreground="{StaticResource TxtBrush}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource RelayIconClipboard}"
                                      Fill="{DynamicResource TxtBrush}"
                                      Width="12" Height="12" Stretch="Uniform"
                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                      SnapsToDevicePixels="True"/>
                                <TextBlock Text="수동 설정 스니펫 (자동 설정이 실패하거나 다른 계정에 적용하려면)"
                                           Style="{StaticResource ExpanderHeaderTB}"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,10,0,0">

                            <TextBlock Text="BASE URL · API KEY" Style="{StaticResource SecTitle}"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="BaseUrlBox" Style="{StaticResource CodeBox}"/>
                                <Button Grid.Column="2" Style="{StaticResource Btn}"
                                        Click="CopyBaseUrl_Click" MinWidth="70">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource BtnIconPath}"
                                              Data="{StaticResource RelayIconClipboard}"/>
                                        <TextBlock Text="복사" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="환경변수 · PowerShell (현재 셸 + 영구 한 번에)" Style="{StaticResource SecTitle}"/>
                            <TextBlock Text="이 스니펫을 PowerShell에 그대로 붙여넣으면, 지금 이 셸에 즉시 적용되고 동시에 사용자 환경변수에도 저장됩니다."
                                       FontSize="10" Foreground="{StaticResource TxtSubBrush}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="EnvBox" Style="{StaticResource CodeBox}"
                                         Height="150"/>
                                <Button Grid.Column="2" Style="{StaticResource Btn}"
                                        Click="CopyEnv_Click" MinWidth="70" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource BtnIconPath}"
                                              Data="{StaticResource RelayIconClipboard}"/>
                                        <TextBlock Text="복사" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="환경변수 · cmd.exe (set + setx 쌍)" Style="{StaticResource SecTitle}"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="EnvCmdBox" Style="{StaticResource CodeBox}"
                                         Height="130"/>
                                <Button Grid.Column="2" Style="{StaticResource Btn}"
                                        Click="CopyEnvCmd_Click" MinWidth="70" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource BtnIconPath}"
                                              Data="{StaticResource RelayIconClipboard}"/>
                                        <TextBlock Text="복사" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                        </StackPanel>
                    </Expander>

                    <Expander Margin="0,0,0,4" IsExpanded="False" Foreground="{StaticResource TxtBrush}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource RelayIconCode}"
                                      Fill="{DynamicResource TxtBrush}"
                                      Width="12" Height="12" Stretch="Uniform"
                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                      SnapsToDevicePixels="True"/>
                                <TextBlock Text="내 코드에서 사용하는 예시 (cURL / Python / Node.js)"
                                           Style="{StaticResource ExpanderHeaderTB}"/>
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="0,10,0,0">

                            <TextBlock Text="cURL 예제" Style="{StaticResource SecTitle}"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="CurlBox" Style="{StaticResource CodeBox}"
                                         Height="90"/>
                                <Button Grid.Column="2" Style="{StaticResource Btn}"
                                        Click="CopyCurl_Click" MinWidth="70" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource BtnIconPath}"
                                              Data="{StaticResource RelayIconClipboard}"/>
                                        <TextBlock Text="복사" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="Python (google-generativeai)" Style="{StaticResource SecTitle}"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="PyLegacyBox" Style="{StaticResource CodeBox}"
                                         Height="130"/>
                                <Button Grid.Column="2" Style="{StaticResource Btn}"
                                        Click="CopyPyLegacy_Click" MinWidth="70" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource BtnIconPath}"
                                              Data="{StaticResource RelayIconClipboard}"/>
                                        <TextBlock Text="복사" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="Python (google-genai · 최신 통합 SDK)" Style="{StaticResource SecTitle}"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="PyNewBox" Style="{StaticResource CodeBox}"
                                         Height="110"/>
                                <Button Grid.Column="2" Style="{StaticResource Btn}"
                                        Click="CopyPyNew_Click" MinWidth="70" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource BtnIconPath}"
                                              Data="{StaticResource RelayIconClipboard}"/>
                                        <TextBlock Text="복사" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="Node.js (@google/generative-ai)" Style="{StaticResource SecTitle}"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="NodeBox" Style="{StaticResource CodeBox}"
                                         Height="110"/>
                                <Button Grid.Column="2" Style="{StaticResource Btn}"
                                        Click="CopyNode_Click" MinWidth="70" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource BtnIconPath}"
                                              Data="{StaticResource RelayIconClipboard}"/>
                                        <TextBlock Text="복사" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                        </StackPanel>
                    </Expander>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Status strip -->
        <Border Grid.Row="2" Background="{StaticResource BgTitleBarBrush}"
                BorderBrush="{StaticResource BorderBrushBase}"
                BorderThickness="0,1,0,0" Padding="14,8">
            <TextBlock x:Name="StatusText" Text="" FontSize="11" Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
