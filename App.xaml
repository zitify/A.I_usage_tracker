<Application x:Class="AIUsageTracker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AIUsageTracker.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/DarkTheme.xaml"/>
                <ResourceDictionary Source="Styles/BrandIcons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:StatusTokenToBgConverter x:Key="StatusTokenToBgConverter"/>
            <conv:StatusTokenToFgConverter x:Key="StatusTokenToFgConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
