<Window x:Class="AIUsageTracker.Views.AppIconSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="앱 아이콘 설정"
        Width="560" Height="520"
        Background="{StaticResource BgBaseBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="앱 아이콘" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource TxtHighlightBrush}"/>

        <TextBlock Grid.Row="1" Margin="0,4,0,16" FontSize="11" TextWrapping="Wrap"
                   Foreground="{StaticResource TxtSubBrush}">
            실행 중 윈도우 · 작업표시줄 · 시스템 트레이의 아이콘을 변경합니다.
            <LineBreak/>
            <Run FontWeight="SemiBold" Foreground="{StaticResource AccentYellowBrush}">참고:</Run>
            Windows 탐색기 · 시작메뉴 · 핀 고정한 바로가기의 아이콘은 빌드 시 .exe 에 박혀 있어 변경되지 않습니다.
        </TextBlock>

        <!-- 빌트인 3개 -->
        <TextBlock Grid.Row="2" Text="빌트인 컨셉" Style="{StaticResource Sec}"/>

        <UniformGrid Grid.Row="3" Columns="3" Rows="1" Margin="0,6,0,12">
            <Border x:Name="ChoiceA" Tag="builtin:A" Margin="6"
                    Background="{StaticResource BgInputBrush}"
                    BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="2"
                    CornerRadius="8" Padding="10" Cursor="Hand"
                    MouseLeftButtonDown="Choice_Click">
                <StackPanel>
                    <Image Source="pack://application:,,,/Assets/icons/icon-A-paw-chart.png"
                           Width="120" Height="120" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="A · Paw + Chart" FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="발자국 + 막대 차트" FontSize="10"
                               Foreground="{StaticResource TxtSubBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border x:Name="ChoiceB" Tag="builtin:B" Margin="6"
                    Background="{StaticResource BgInputBrush}"
                    BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="2"
                    CornerRadius="8" Padding="10" Cursor="Hand"
                    MouseLeftButtonDown="Choice_Click">
                <StackPanel>
                    <Image Source="pack://application:,,,/Assets/icons/icon-B-quota-ring.png"
                           Width="120" Height="120" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="B · Quota Ring" FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="미니멀 진행 링" FontSize="10"
                               Foreground="{StaticResource TxtSubBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border x:Name="ChoiceC" Tag="builtin:C" Margin="6"
                    Background="{StaticResource BgInputBrush}"
                    BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="2"
                    CornerRadius="8" Padding="10" Cursor="Hand"
                    MouseLeftButtonDown="Choice_Click">
                <StackPanel>
                    <Image Source="pack://application:,,,/Assets/icons/icon-C-dual-corgi.png"
                           Width="120" Height="120" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="C · Dual Corgi" FontSize="11" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="듀얼 테마 코기" FontSize="10"
                               Foreground="{StaticResource TxtSubBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 사용자 파일 선택 -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="직접 선택 (.ico / .png)"
                       Style="{StaticResource Sec}"/>
            <TextBox Grid.Row="1" Grid.Column="0" x:Name="CustomPathBox"
                     IsReadOnly="True"
                     ToolTip="사용자 파일 경로 — 찾아보기 버튼으로 선택"/>
            <Button Grid.Row="1" Grid.Column="2" Content="찾아보기..."
                    Style="{StaticResource Btn}" Click="Browse_Click" MinWidth="100"/>
        </Grid>

        <!-- 액션 -->
        <Grid Grid.Row="5" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="기본값으로 복원" Style="{StaticResource Btn}"
                    Click="Reset_Click"/>
            <TextBlock Grid.Column="1" x:Name="StatusLabel" FontSize="11"
                       Foreground="{StaticResource TxtSubBrush}"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
            <Button Grid.Column="2" Content="취소" Style="{StaticResource Btn}"
                    Click="Cancel_Click" IsCancel="True"/>
            <Button Grid.Column="4" Content="적용" Style="{StaticResource BtnPrimary}"
                    Click="Apply_Click" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
