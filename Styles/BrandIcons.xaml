<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Chrome (titlebar) button icons — Geometry vector data, 12×12 viewport ═══
         Path 으로 렌더되어 폰트 폴백(컬러 이모지 등)의 영향을 받지 않고
         Foreground 토큰을 정확히 따른다. -->
    <Geometry x:Key="ChromeIconThemeDark">M6,0 A6,6 0 0 0 6,12 Z</Geometry>           <!-- 좌반원 ◐ -->
    <Geometry x:Key="ChromeIconThemeDog">M6,0 A6,6 0 0 1 6,12 Z</Geometry>            <!-- 우반원 ◑ -->
    <Geometry x:Key="ChromeIconTopmost">M6,1 L11,7 L8,7 L8,11 L4,11 L4,7 L1,7 Z</Geometry>  <!-- 위쪽 화살표 -->
    <Geometry x:Key="ChromeIconMin">M0,5 L12,5 L12,7 L0,7 Z</Geometry>                <!-- 가는 가로줄 — -->
    <Geometry x:Key="ChromeIconMax">F0 M0,1 L12,1 L12,11 L0,11 Z M2,3 L2,9 L10,9 L10,3 Z</Geometry> <!-- 사각형 윤곽 ☐ (EvenOdd) -->
    <Geometry x:Key="ChromeIconClose">M0,2 L2,0 L6,4 L10,0 L12,2 L8,6 L12,10 L10,12 L6,8 L2,12 L0,10 L4,6 Z</Geometry> <!-- 두꺼운 X -->

    <!-- Anthropic Claude: orange 8-spoke asterisk (#D97757) -->
    <SolidColorBrush x:Key="ClaudeBrandBrush" Color="#D97757"/>

    <Style x:Key="ClaudeBrandIcon" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Viewbox Stretch="Uniform">
                        <Grid Width="24" Height="24">
                            <Ellipse Width="3.6" Height="20" Fill="{StaticResource ClaudeBrandBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="3.6" Height="20" Fill="{StaticResource ClaudeBrandBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><RotateTransform Angle="45"/></Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="3.6" Height="20" Fill="{StaticResource ClaudeBrandBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><RotateTransform Angle="90"/></Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="3.6" Height="20" Fill="{StaticResource ClaudeBrandBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><RotateTransform Angle="135"/></Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Google Gemini: 4-point sparkle with blue→purple gradient -->
    <LinearGradientBrush x:Key="GeminiBrandBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1BA1E2" Offset="0"/>
        <GradientStop Color="#4F7CE8" Offset="0.5"/>
        <GradientStop Color="#9B72CB" Offset="1"/>
    </LinearGradientBrush>

    <Geometry x:Key="GeminiSparkleGeometry">M 12,0 C 13.2,6.8 17.2,10.8 24,12 C 17.2,13.2 13.2,17.2 12,24 C 10.8,17.2 6.8,13.2 0,12 C 6.8,10.8 10.8,6.8 12,0 Z</Geometry>

    <Style x:Key="GeminiBrandIcon" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Viewbox Stretch="Uniform">
                        <Path Data="{StaticResource GeminiSparkleGeometry}"
                              Fill="{StaticResource GeminiBrandBrush}"
                              Width="24" Height="24" Stretch="Uniform"/>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
